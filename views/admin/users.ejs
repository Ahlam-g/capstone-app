<%- include('../partials/header', { user, title: 'Manage Users' }) %>

<div class="flex items-center justify-between" style="margin-bottom:1.5rem;">
  <h1 style="margin:0;">Users (<%= users.length %>)</h1>
  <a href="/admin" class="btn btn-secondary btn-sm">← Dashboard</a>
</div>

<% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
<% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

<div class="card" style="padding:0; overflow:hidden;">
  <table>
    <thead>
      <tr>
        <th>Email</th>
        <th>Full Name</th>
        <th>Role</th>
        <th>Joined</th>
        <th>Change Role</th>
        <th>Delete</th>
        <th>Ban</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(u => { %>
        <tr>
          <td>
            <%= u.email %>
            <% if (u.is_banned) { %>
              <span style="margin-left:.4rem; font-size:.7rem; font-weight:600; padding:.15rem .4rem;
                border-radius:999px; background:#fef2f2; color:#b91c1c;">banned</span>
            <% } %>
          </td>
          <td><%= u.full_name || '—' %></td>
          <td>
            <span style="font-size:.8rem; font-weight:600; padding:.2rem .5rem; border-radius:999px;
              background:<%= u.role==='admin' ? '#fee2e2' : u.role==='manager' ? '#e0e7ff' : '#f3f4f6' %>;
              color:<%= u.role==='admin' ? '#991b1b' : u.role==='manager' ? '#4338ca' : '#374151' %>;">
              <%= u.role %>
            </span>
          </td>
          <td><%= new Date(u.created_at).toLocaleDateString('en-US', { dateStyle: 'medium' }) %></td>
          <td>
            <% if (u.id !== user.id) { %>
              <form method="POST" action="/admin/users/<%= u.id %>/role" class="flex gap-1 items-center">
                <select name="role" style="padding:.3rem .5rem; border:1px solid #d1d5db; border-radius:6px; font-size:.85rem;">
                  <option value="user"    <%= u.role==='user'    ? 'selected' : '' %>>user</option>
                  <option value="manager" <%= u.role==='manager' ? 'selected' : '' %>>manager</option>
                  <option value="admin"   <%= u.role==='admin'   ? 'selected' : '' %>>admin</option>
                </select>
                <button type="submit" class="btn btn-secondary btn-sm">Save</button>
              </form>
            <% } else { %>
              <span class="text-muted">You</span>
            <% } %>
          </td>
          <td>
            <% if (u.id !== user.id) { %>
              <form method="POST" action="/admin/users/<%= u.id %>/delete"
                    data-uemail="<%= u.email %>"
                    onsubmit="return confirm('Delete user ' + this.getAttribute('data-uemail') + '? All their data will be removed.')">
                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
              </form>
            <% } else { %>
              —
            <% } %>
          </td>
          <td>
            <% if (u.id !== user.id) { %>
              <% if (u.is_banned) { %>
                <form method="POST" action="/admin/users/<%= u.id %>/unban">
                  <button type="submit" class="btn btn-secondary btn-sm">Unban</button>
                </form>
              <% } else { %>
                <form method="POST" action="/admin/users/<%= u.id %>/ban"
                      data-uemail="<%= u.email %>"
                      onsubmit="return confirm('Ban ' + this.getAttribute('data-uemail') + '? They will be locked out immediately.')">
                  <button type="submit" class="btn btn-danger btn-sm">Ban</button>
                </form>
              <% } %>
            <% } else { %>
              —
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
