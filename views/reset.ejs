<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Reset Password — Ticketing App</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: system-ui, -apple-system, sans-serif;
      background: #f5f5f5;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 1rem;
    }

    .card {
      background: #fff;
      border-radius: 8px;
      box-shadow: 0 2px 12px rgba(0,0,0,.08);
      padding: 2.5rem 2rem;
      width: 100%;
      max-width: 400px;
    }

    h1 {
      font-size: 1.5rem;
      margin-bottom: .5rem;
      color: #111;
    }

    .subtitle {
      font-size: .875rem;
      color: #6b7280;
      margin-bottom: 1.5rem;
    }

    .error-banner {
      background: #fef2f2;
      border: 1px solid #fca5a5;
      border-radius: 6px;
      color: #b91c1c;
      font-size: .875rem;
      padding: .75rem 1rem;
      margin-bottom: 1.25rem;
    }

    label {
      display: block;
      font-size: .875rem;
      font-weight: 500;
      color: #374151;
      margin-bottom: .35rem;
    }

    input[type="password"] {
      width: 100%;
      padding: .6rem .75rem;
      border: 1px solid #d1d5db;
      border-radius: 6px;
      font-size: 1rem;
      margin-bottom: 1rem;
      transition: border-color .15s;
    }

    input:focus {
      outline: none;
      border-color: #6366f1;
      box-shadow: 0 0 0 3px rgba(99,102,241,.15);
    }

    button[type="submit"] {
      width: 100%;
      padding: .65rem;
      background: #6366f1;
      color: #fff;
      border: none;
      border-radius: 6px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: background .15s;
    }

    button[type="submit"]:hover { background: #4f46e5; }

    .footer-link {
      text-align: center;
      margin-top: 1.25rem;
      font-size: .875rem;
      color: #6b7280;
    }

    .footer-link a { color: #6366f1; text-decoration: none; }
    .footer-link a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <div class="card">
    <h1>Reset Password</h1>

    <% if (!token) { %>
      <div class="error-banner" role="alert"><%= error %></div>
      <p class="footer-link" style="margin-top:1rem;">
        <a href="/forgot">Request a new reset link</a>
      </p>
    <% } else { %>
      <p class="subtitle">Enter your new password below.</p>

      <% if (error) { %>
        <div class="error-banner" role="alert"><%= error %></div>
      <% } %>

      <form method="POST" action="/reset/<%= token %>" novalidate>
        <label for="new_password">New password</label>
        <input
          type="password"
          id="new_password"
          name="new_password"
          autocomplete="new-password"
          required
          autofocus
          minlength="8"
        />

        <label for="confirm_password">Confirm new password</label>
        <input
          type="password"
          id="confirm_password"
          name="confirm_password"
          autocomplete="new-password"
          required
          minlength="8"
        />

        <button type="submit">Set New Password</button>
      </form>

      <p class="footer-link">
        <a href="/login">Back to sign in</a>
      </p>
    <% } %>
  </div>
</body>
</html>
