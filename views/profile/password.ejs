<%- include('../partials/header', { user, title: 'Change Password' }) %>

<div style="max-width:480px; margin:0 auto;">
  <div class="flex items-center justify-between" style="margin-bottom:1.5rem;">
    <h1 style="margin:0;">Change Password</h1>
    <a href="/profile" class="btn btn-secondary btn-sm">← Back</a>
  </div>

  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <div class="card">
    <form method="POST" action="/profile/password">

      <div class="form-group">
        <label for="current_password">Current Password</label>
        <input type="password" id="current_password" name="current_password" required autocomplete="current-password" />
      </div>

      <div class="form-group">
        <label for="new_password">New Password</label>
        <input type="password" id="new_password" name="new_password" required minlength="8" autocomplete="new-password" />
        <p class="text-muted" style="margin-top:.25rem; font-size:.8rem;">At least 8 characters</p>
      </div>

      <div class="form-group">
        <label for="confirm_password">Confirm New Password</label>
        <input type="password" id="confirm_password" name="confirm_password" required autocomplete="new-password" />
      </div>

      <button type="submit" class="btn btn-primary">Update Password</button>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
