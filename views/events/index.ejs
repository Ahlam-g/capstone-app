<%- include('../partials/header', { user, title: 'Events' }) %>

<div class="flex items-center justify-between mb-1">
  <h1 style="margin-bottom:0">Upcoming Events</h1>
</div>

<form method="GET" action="/events" class="card" style="margin-bottom:1.5rem; padding:1rem;">
  <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(180px,1fr)); gap:.75rem; align-items:end;">
    <div class="form-group" style="margin-bottom:0;">
      <label>Search</label>
      <input type="text" name="q" placeholder="Title or venue…" value="<%= filters.q || '' %>" />
    </div>
    <div class="form-group" style="margin-bottom:0;">
      <label>Venue</label>
      <input type="text" name="venue" placeholder="Venue…" value="<%= filters.venue || '' %>" />
    </div>
    <div class="form-group" style="margin-bottom:0;">
      <label>Min price ($)</label>
      <input type="number" name="minPrice" min="0" step="0.01" placeholder="0.00"
             value="<%= filters.minPrice != null ? filters.minPrice : '' %>" />
    </div>
    <div class="form-group" style="margin-bottom:0;">
      <label>Max price ($)</label>
      <input type="number" name="maxPrice" min="0" step="0.01" placeholder="Any"
             value="<%= filters.maxPrice != null ? filters.maxPrice : '' %>" />
    </div>
    <div class="form-group" style="margin-bottom:0;">
      <label>From date</label>
      <input type="date" name="dateFrom" value="<%= filters.dateFrom || '' %>" />
    </div>
    <div class="form-group" style="margin-bottom:0;">
      <label>To date</label>
      <input type="date" name="dateTo" value="<%= filters.dateTo || '' %>" />
    </div>
    <div style="display:flex; gap:.5rem;">
      <button type="submit" class="btn btn-primary" style="flex:1;">Search</button>
      <a href="/events" class="btn btn-secondary">Clear</a>
    </div>
  </div>
</form>

<% if (events.length === 0) { %>
  <div class="card" style="text-align:center; padding:3rem;">
    <p class="text-muted">No events scheduled yet. Check back soon!</p>
  </div>
<% } else { %>
  <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:1.5rem; margin-top:1.5rem;">
    <% events.forEach(event => { %>
      <a href="/events/<%= event.id %>" style="text-decoration:none; color:inherit;">
        <div class="card" style="padding:0; overflow:hidden; transition:box-shadow .15s;">
          <% if (event.image_path) { %>
            <img src="<%= event.image_path %>" alt="<%= event.title %>"
                 style="width:100%; height:180px; object-fit:cover;" />
          <% } else { %>
            <div style="width:100%; height:180px; background:#e0e7ff; display:flex; align-items:center; justify-content:center; color:#6366f1; font-size:2rem;">
              🎟
            </div>
          <% } %>
          <div style="padding:1rem;">
            <h2 style="margin-bottom:.35rem; font-size:1.1rem;"><%= event.title %></h2>
            <p class="text-muted" style="margin-bottom:.5rem;">
              📅 <%= new Date(event.date).toLocaleDateString('en-US', { dateStyle: 'medium' }) %>
              &nbsp;·&nbsp;
              📍 <%= event.venue %>
            </p>
            <div class="flex items-center justify-between">
              <span style="font-weight:600; color:#6366f1;">$<%= Number(event.price).toFixed(2) %></span>
              <% if (event.tickets_remaining > 0) { %>
                <span style="font-size:.8rem; color:#166534; background:#f0fdf4; padding:.2rem .5rem; border-radius:999px;">
                  <%= event.tickets_remaining %> left
                </span>
              <% } else { %>
                <span style="font-size:.8rem; color:#b91c1c; background:#fef2f2; padding:.2rem .5rem; border-radius:999px;">
                  Sold out
                </span>
              <% } %>
            </div>
          </div>
        </div>
      </a>
    <% }) %>
  </div>
<% } %>

<%- include('../partials/footer') %>
